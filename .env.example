# Porta do servidor
PORT=3000

# Conexão com o banco (PostgreSQL)
# Exemplo: postgres://usuario:senha@localhost:5432/nome_db
DATABASE_URL=postgres://user:password@localhost:5432/gestao_restaurante

# Autenticação JWT
JWT_SECRET=troque_esta_chave
JWT_EXPIRES_IN=1d

# Super Admin (criado automaticamente na primeira execução)
NOME_SUPER_ADMIN=Administrador
MATRICULA_SUPER_ADMIN=00001
EMAIL_SUPER_ADMIN=admin@exemplo.com
SENHA_SUPER_ADMIN=senha_forte_aqui
TELEFONE_SUPER_ADMIN=11999999999
